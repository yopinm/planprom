# =============================================================================
# couponkum.com - Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local - it is gitignored.
# =============================================================================

# --- App ---
NEXT_PUBLIC_BASE_URL=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Lazada Open API ---
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_USER_TOKEN=

# --- Shopee Affiliate API ---
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=

# --- Involve Asia REST API (AFFNET-IA-API) ---
# Bearer token for api.involve.asia/v2 — set when key is received (ETA 2026-05-06)
# When absent: involve-asia-import cron runs in SAFE MODE (no DB writes, no error)
# VPS crontab (add when ready): 0 */6 * * * curl -s "http://localhost:3000/api/cron/involve-asia-import?secret=$CRON_SECRET"
IA_REST_API_KEY=

# Deep link base for Shopee search fallback; append encoded destination URL.
# Example: https://invol.pe/cl1abc?dl=
INVOLVE_ASIA_SHOPEE_SEARCH_BASE=

# --- Cloudflare ---
CLOUDFLARE_WORKER_URL=
CLOUDFLARE_API_TOKEN=

# --- Monitoring (TASK 5.1) ---
# Server-side DSN (sentry.server.config.ts + sentry.edge.config.ts)
SENTRY_DSN=
# Client-side DSN (sentry.client.config.ts) - safe to expose publicly
NEXT_PUBLIC_SENTRY_DSN=
# Source map upload (CI only - never commit this value)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Cache ---
REDIS_URL=

# --- Revenue Tracking / S2S Postback (TASK 4.10a) ---
# HMAC-SHA256 secret shared with affiliate network (Shopee + Lazada)
REVENUE_WEBHOOK_SECRET=

# --- Campaign Mode (TASK 2.13) ---
# Set to 'true' to force peak mode (manual override; otherwise auto-detected from date)
PEAK_MODE=false
# Shared secret for cron endpoints (prewarm, alert-scanner)
CRON_SECRET=

# --- LINE Notify (TASK 2.8.1) — DEPRECATED March 2025, kept for reference only ---
LINE_NOTIFY_TOKEN=

# --- LINE Messaging API / OA (WALLET-LINE-1) ---
# Create a LINE Official Account + enable Messaging API at developers.line.biz
# Webhook URL to register: https://couponkum.com/api/webhook/line
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# LINE OA's @ID (e.g. @abc1234) — safe to expose publicly (used in deep links)
NEXT_PUBLIC_LINE_OA_ID=

# --- Facebook Graph API (TASK 3.17+) ---
# Server-side only. Never expose these through NEXT_PUBLIC_* variables.
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
# Public Meta App ID for root fb:app_id metadata. Safe to expose; do not put App Secret here.
NEXT_PUBLIC_FACEBOOK_APP_ID=
# Social contact links shown in footer (safe to expose publicly)
NEXT_PUBLIC_FACEBOOK_PAGE_URL=
# Required for validating Facebook webhook POST X-Hub-Signature-256.
FB_APP_SECRET=
# Date/time when the current Meta App Secret was regenerated. Example: 2026-04-23
FB_APP_SECRET_ROTATED_AT=
# Date/time when the current page token was issued or rotated. Example: 2026-04-23
FB_PAGE_ACCESS_TOKEN_ISSUED_AT=
FB_PAGE_ACCESS_TOKEN_ROTATION_DAYS=60
# Conservative auto-reply caps to avoid spam-like behavior.
FB_MAX_AUTO_REPLIES_PER_DAY=20
FB_MAX_AUTO_REPLIES_PER_POST_PER_DAY=5
# Emergency production kill switches. true/1/yes forces automation OFF even if DB settings are enabled.
FB_DISABLE_GRAPH_API_POSTING=false
FB_DISABLE_AUTO_REPLY=false
# Webhook verify token - set a random string, then paste it into Facebook App Webhook settings.
# Register callback URL: https://couponkum.com/api/webhooks/facebook (after hosting is live)
FB_WEBHOOK_VERIFY_TOKEN=

# Web Push / Browser Notifications (POSTLIVE-17 stub -- activate Month 9)
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@couponkum.com
PUSH_NOTIFICATIONS_ENABLED=false

# --- UptimeRobot Webhook (POSTLIVE-02) ---
# Append as ?secret=<UPTIME_WEBHOOK_SECRET> on the UptimeRobot webhook URL.
UPTIME_WEBHOOK_SECRET=
